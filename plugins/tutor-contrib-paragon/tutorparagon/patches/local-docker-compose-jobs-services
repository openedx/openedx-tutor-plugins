# Paragon Builder
paragon-builder-job:
    image: {{ PARAGON_BUILDER_IMAGE }}
    environment:
      - PARAGON_ENABLED_THEMES={{ PARAGON_ENABLED_THEMES | join(',') }}
    volumes:
      - "{% if PARAGON_THEME_SOURCES_PATH.startswith('/') %}{{ PARAGON_THEME_SOURCES_PATH }}{% else %}./../../{{ PARAGON_THEME_SOURCES_PATH }}{% endif %}:/theme-sources"
      - "./../../{{ PARAGON_COMPILED_THEMES_PATH }}:/compiled-themes"
